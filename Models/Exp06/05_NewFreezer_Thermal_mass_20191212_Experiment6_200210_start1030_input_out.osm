OS:EnergyManagementSystem:Program,
  {4c850de9-2345-4919-bbd5-b9b3c9fc6cac}, !- Handle
  AmbientConditionAndInsideConvectionOveride, !- Name
  IF HVAC_SCHEDULE_SENSOR == 1.0,         !- Program Line 1
  SET Conditioned_Zone_East_RoofCeiling_Ext_inside_convection_actuator = Null, !- Program Line 2
  SET Conditioned_Zone_West_Wall_Ext_inside_convection_actuator = Null, !- Program Line 3
  SET Conditioned_Zone_North_Wall_Ext_inside_convection_actuator = Null, !- Program Line 4
  SET Conditioned_Zone_South_Wall_Ext_inside_convection_actuator = Null, !- Program Line 5
  SET Conditioned_Zone_East_Wall_Int_inside_convection_actuator = Null, !- Program Line 6
  SET Conditioned_Zone_East_Floor_Ext_inside_convection_actuator = Null, !- Program Line 7
  SET Conditioned_Zone_East_Wall_Ext_inside_convection_actuator = Null, !- Program Line 8
  SET Conditioned_Zone_East_Wall_Int_1_inside_convection_actuator = Null, !- Program Line 9
  SET ChilledWaterGainActuator = Null,    !- Program Line 10
  SET EnviromentOdbActuator = Null,       !- Program Line 11
  SET EnviromentDirectSolarActuator = Null, !- Program Line 12
  SET EnviromentDiffSolarActuator = Null, !- Program Line 13
  SET EnviromentWindSpeedActuator = Null, !- Program Line 14
  ELSE,                                   !- Program Line 15
  SET Conditioned_Zone_East_RoofCeiling_Ext_inside_convection_actuator = 0.395, !- Program Line 16
  SET Conditioned_Zone_West_Wall_Ext_inside_convection_actuator = 0.395, !- Program Line 17
  SET Conditioned_Zone_North_Wall_Ext_inside_convection_actuator = 0.395, !- Program Line 18
  SET Conditioned_Zone_South_Wall_Ext_inside_convection_actuator = 0.395, !- Program Line 19
  SET Conditioned_Zone_East_Wall_Int_inside_convection_actuator = 0.395, !- Program Line 20
  SET Conditioned_Zone_East_Floor_Ext_inside_convection_actuator = 0.395, !- Program Line 21
  SET Conditioned_Zone_East_Wall_Ext_inside_convection_actuator = 0.395, !- Program Line 22
  SET Conditioned_Zone_East_Wall_Int_1_inside_convection_actuator = 0.395, !- Program Line 23
  IF coolingLoad_VALUE_EMS_SENSOR < 0.0,  !- Program Line 24
  SET ChilledWaterGainActuator = -18,     !- Program Line 25
  ELSE,                                   !- Program Line 26
  SET ChilledWaterGainActuator = Null,    !- Program Line 27
  ENDIF,                                  !- Program Line 28
  SET EnviromentOdbActuator = EMS_OUTDOOR_SENSOR, !- Program Line 29
  SET EnviromentDirectSolarActuator = 0,  !- Program Line 30
  SET EnviromentDiffSolarActuator = 0,    !- Program Line 31
  SET EnviromentWindSpeedActuator = 0,    !- Program Line 32
  ENDIF;                                  !- Program Line 33

